{
    "name": "oidc-client/sdk",
    "description": "Framework Agnostic OpenID Connect Client SDK",
    "type": "composer-plugin",
    "license": "MIT",

    "require": {
        "php": "^8.1",
        "composer-plugin-api": "^2.0"
    },

    "autoload": {
        "psr-4": {
            "OidcClient\\": "packages/php/core/src/",
            "OidcClient\\Composer\\": "src/Composer/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },

    "require-dev": {
        "phpunit/phpunit": "^13.2"
    },
    "extra": {
        "laravel": {
            "providers": [
                "OidcClient\\Integration\\Laravel\\OidcServiceProvider"
            ]
        }
    }
}
